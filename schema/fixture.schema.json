{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/CharlieTap/wasm-corpus/main/schema/fixture.schema.json",
  "title": "wasm-corpus fixture metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "path",
    "wat",
    "features",
    "tests",
    "sha256",
    "source"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
    },
    "path": {
      "type": "string",
      "pattern": "^[^/].*\\.wasm$"
    },
    "wat": {
      "$ref": "#/$defs/wat"
    },
    "description": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      },
      "uniqueItems": true
    },
    "imports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/import"
      }
    },
    "exports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/export"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/test"
      },
      "minItems": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "toolchain": {
      "$ref": "#/$defs/toolchain"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "wat": {
      "oneOf": [
        {
          "$ref": "#/$defs/presentWat"
        },
        {
          "$ref": "#/$defs/tooLargeWat"
        }
      ]
    },
    "presentWat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "path"
      ],
      "properties": {
        "status": {
          "const": "present"
        },
        "path": {
          "type": "string",
          "pattern": "^[^/].*\\.wat$"
        }
      }
    },
    "tooLargeWat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "generated_size",
        "limit",
        "tool"
      ],
      "properties": {
        "status": {
          "const": "too_large_for_corpus"
        },
        "generated_size": {
          "type": "integer",
          "minimum": 1
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        },
        "tool": {
          "type": "string"
        }
      }
    },
    "feature": {
      "type": "string",
      "enum": [
        "big-int",
        "branch-hinting",
        "bulk-memory",
        "compact-import-section",
        "compilation-hints",
        "component-model",
        "custom-annotation-syntax-in-the-text-format",
        "custom-descriptors",
        "custom-page-sizes",
        "esm-integration",
        "exception-handling",
        "extended-const",
        "extended-name-section",
        "flexible-vectors",
        "frozen-values",
        "gc",
        "half-precision",
        "jit-interface",
        "js-primitive-builtins",
        "js-string-builtins",
        "jspi",
        "memory-control",
        "memory64",
        "more-array-constructors",
        "multi-memory",
        "multi-value",
        "multibyte-array-access",
        "mutable-globals",
        "numeric-values-in-wat",
        "profiles",
        "reference-types",
        "relaxed-dead-code-validation",
        "relaxed-simd",
        "rounding-variants",
        "saturated-float-to-int",
        "shared-everything-threads",
        "sign-extensions",
        "simd",
        "stack-switching",
        "stringref",
        "tail-call",
        "threads",
        "type-imports",
        "type-reflection",
        "typed-function-references",
        "wasm-c-api",
        "web-content-security-policy",
        "wide-arithmetic"
      ]
    },
    "import": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module",
        "name",
        "kind"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "function"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "stub": {
                "$ref": "#/$defs/functionImportStub"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "global"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "stub": {
                "$ref": "#/$defs/globalImportStub"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "memory",
                  "table",
                  "tag"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "not": {
              "required": [
                "stub"
              ]
            }
          }
        }
      ],
      "properties": {
        "module": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "function",
            "global",
            "memory",
            "table",
            "tag"
          ]
        },
        "type": {
          "type": "string"
        },
        "stub": {
          "$ref": "#/$defs/importStub"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "importStub": {
      "oneOf": [
        {
          "$ref": "#/$defs/functionImportStub"
        },
        {
          "$ref": "#/$defs/globalImportStub"
        }
      ]
    },
    "functionImportStub": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value"
          },
          "default": []
        },
        "returns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value"
          },
          "default": []
        },
        "trap": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "not": {
        "required": [
          "returns",
          "trap"
        ]
      }
    },
    "globalImportStub": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/value"
        },
        "mutable": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "function",
            "global",
            "memory",
            "table",
            "tag"
          ]
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "shared_instance": {
          "type": "boolean",
          "default": false
        },
        "host": {
          "$ref": "#/$defs/host"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          },
          "minItems": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "step": {
      "oneOf": [
        {
          "$ref": "#/$defs/invokeStep"
        },
        {
          "$ref": "#/$defs/memoryWriteStep"
        },
        {
          "$ref": "#/$defs/memoryReadStep"
        },
        {
          "$ref": "#/$defs/globalReadStep"
        },
        {
          "$ref": "#/$defs/globalWriteStep"
        },
        {
          "$ref": "#/$defs/tableWriteStep"
        },
        {
          "$ref": "#/$defs/tableReadStep"
        }
      ]
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wasi_preview_1": {
          "$ref": "#/$defs/wasiPreview1Host"
        }
      }
    },
    "wasiPreview1Host": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "system_env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "preopened_directories": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "stdin": {
          "$ref": "#/$defs/bytes"
        }
      }
    },
    "invokeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "function",
        "params",
        "results"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "function.invoke"
        },
        "function": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/valueExpression"
          },
          "default": []
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resultValue"
          }
        },
        "trap": {
          "type": "string"
        },
        "host_effects": {
          "$ref": "#/$defs/hostEffectsAssertion"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "memoryWriteStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "offset"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "memory.write"
        },
        "memory": {
          "type": "string",
          "default": "memory"
        },
        "offset": {
          "$ref": "#/$defs/integerExpression"
        },
        "bytes": {
          "$ref": "#/$defs/bytes"
        },
        "value": {
          "$ref": "#/$defs/valueExpression"
        },
        "notes": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "required": [
            "bytes"
          ]
        },
        {
          "required": [
            "value"
          ]
        }
      ]
    },
    "memoryReadStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "offset"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "memory.read"
        },
        "memory": {
          "type": "string",
          "default": "memory"
        },
        "offset": {
          "$ref": "#/$defs/integerExpression"
        },
        "length": {
          "$ref": "#/$defs/integerExpression"
        },
        "assert": {
          "$ref": "#/$defs/memoryReadAssertion"
        },
        "capture": {
          "$ref": "#/$defs/memoryReadCapture"
        },
        "notes": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "required": [
            "assert"
          ]
        },
        {
          "required": [
            "capture"
          ]
        }
      ]
    },
    "globalReadStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "global",
        "assert"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "global.read"
        },
        "global": {
          "type": "string"
        },
        "assert": {
          "$ref": "#/$defs/valueAssertion"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "globalWriteStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "global",
        "value"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "global.write"
        },
        "global": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/valueExpression"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tableWriteStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "index",
        "value"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "table.write"
        },
        "table": {
          "type": "string",
          "default": "table"
        },
        "index": {
          "$ref": "#/$defs/integerExpression"
        },
        "value": {
          "$ref": "#/$defs/tableValue"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tableReadStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "index",
        "assert"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "type": {
          "const": "table.read"
        },
        "table": {
          "type": "string",
          "default": "table"
        },
        "index": {
          "$ref": "#/$defs/integerExpression"
        },
        "assert": {
          "$ref": "#/$defs/valueAssertion"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "hostEffectsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exit_code": {
          "type": "integer",
          "minimum": 0
        },
        "stdout": {
          "$ref": "#/$defs/bytesAssertion"
        },
        "stderr": {
          "$ref": "#/$defs/bytesAssertion"
        }
      }
    },
    "trapAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "message"
      ],
      "properties": {
        "type": {
          "const": "trap"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "bytesAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "bytes"
      ],
      "properties": {
        "type": {
          "const": "bytes"
        },
        "bytes": {
          "$ref": "#/$defs/bytes"
        }
      }
    },
    "memoryReadAssertion": {
      "oneOf": [
        {
          "$ref": "#/$defs/bytesAssertion"
        },
        {
          "$ref": "#/$defs/valueAssertion"
        }
      ]
    },
    "memoryReadCapture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "capture"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/numericValueType"
        },
        "capture": {
          "$ref": "#/$defs/variableName"
        }
      }
    },
    "valueAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "const": "value"
        },
        "value": {
          "$ref": "#/$defs/valueAssertionValue"
        }
      }
    },
    "bytes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "encoding",
        "value"
      ],
      "properties": {
        "encoding": {
          "type": "string",
          "enum": [
            "hex",
            "base64",
            "utf8"
          ]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "tableValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/nullReferenceValue"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "export"
          ],
          "properties": {
            "type": {
              "const": "funcref"
            },
            "export": {
              "type": "string"
            }
          }
        }
      ]
    },
    "value": {
      "oneOf": [
        {
          "$ref": "#/$defs/numericValue"
        },
        {
          "$ref": "#/$defs/nullReferenceValue"
        }
      ]
    },
    "valueAssertionValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/value"
        },
        {
          "$ref": "#/$defs/typeOnlyValue"
        }
      ]
    },
    "resultValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/valueAssertionValue"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "capture"
          ],
          "properties": {
            "type": {
              "oneOf": [
                {
                  "$ref": "#/$defs/numericValueType"
                },
                {
                  "$ref": "#/$defs/referenceValueType"
                }
              ]
            },
            "value": {
              "type": [
                "string",
                "null"
              ]
            },
            "capture": {
              "$ref": "#/$defs/variableName"
            }
          }
        }
      ]
    },
    "valueExpression": {
      "oneOf": [
        {
          "$ref": "#/$defs/value"
        },
        {
          "$ref": "#/$defs/variableValue"
        }
      ]
    },
    "numericValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/numericValueType"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "variableValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "var"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/numericValueType"
        },
        "var": {
          "$ref": "#/$defs/variableName"
        }
      }
    },
    "nullReferenceValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/referenceValueType"
        },
        "value": {
          "const": null
        }
      }
    },
    "typeOnlyValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "oneOf": [
            {
              "$ref": "#/$defs/numericValueType"
            },
            {
              "$ref": "#/$defs/referenceValueType"
            }
          ]
        }
      }
    },
    "numericValueType": {
      "type": "string",
      "enum": [
        "i32",
        "i64",
        "f32",
        "f64"
      ]
    },
    "referenceValueType": {
      "type": "string",
      "enum": [
        "externref",
        "funcref"
      ]
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "integerExpression": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "var"
          ],
          "properties": {
            "var": {
              "$ref": "#/$defs/variableName"
            }
          }
        }
      ]
    },
    "variableName": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contributor": {
          "type": "string",
          "enum": [
            "human",
            "ai"
          ]
        },
        "language": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "contributor"
      ]
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    }
  }
}
