#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");

const repoRoot = __dirname;
const versionDirs = ["1.0", "2.0", "3.0"];

function usage(stream = process.stderr) {
  stream.write(`Usage: ./corpus [filters]

Prints corpus fixture metadata as one JSON array. With no filters, all fixtures
are returned in version order: 1.0, then 2.0, then 3.0.

Filters:
  --version <version>       Include fixtures from this version directory.
                            May be repeated or comma-separated.
  --feature <feature>       Require a feature. May be repeated or comma-separated.
  --features <feature>      Alias for --feature.
  --tag <tag>               Require a tag. May be repeated or comma-separated.
  --tags <tag>              Alias for --tag.
  --compact                 Print compact JSON instead of pretty JSON.
  -h, --help                Show this help.

Examples:
  ./corpus
  ./corpus --version 2.0
  ./corpus --feature simd --tag npm
  ./corpus --version 1.0,2.0 --features bulk-memory,simd --compact
`);
}

function fail(message) {
  process.stderr.write(`error: ${message}\n\n`);
  usage();
  process.exit(1);
}

function appendValues(target, rawValue, flag) {
  if (!rawValue || rawValue.startsWith("--")) {
    fail(`${flag} requires a value`);
  }

  for (const value of rawValue.split(",")) {
    const trimmed = value.trim();
    if (trimmed) target.push(trimmed);
  }
}

function parseArgs(argv) {
  const filters = {
    versions: [],
    features: [],
    tags: [],
    compact: false,
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "-h" || arg === "--help") {
      usage(process.stdout);
      process.exit(0);
    }

    if (arg === "--compact") {
      filters.compact = true;
      continue;
    }

    const equalsIndex = arg.indexOf("=");
    const flag = equalsIndex === -1 ? arg : arg.slice(0, equalsIndex);
    const inlineValue = equalsIndex === -1 ? null : arg.slice(equalsIndex + 1);

    if (flag === "--version") {
      appendValues(filters.versions, inlineValue ?? argv[++index], flag);
    } else if (flag === "--feature" || flag === "--features") {
      appendValues(filters.features, inlineValue ?? argv[++index], flag);
    } else if (flag === "--tag" || flag === "--tags") {
      appendValues(filters.tags, inlineValue ?? argv[++index], flag);
    } else {
      fail(`unknown argument: ${arg}`);
    }
  }

  for (const version of filters.versions) {
    if (!versionDirs.includes(version)) {
      fail(`unsupported version filter: ${version}`);
    }
  }

  return filters;
}

function readFixtures() {
  const fixtures = [];

  for (const version of versionDirs) {
    const versionDir = path.join(repoRoot, version);
    if (!fs.existsSync(versionDir)) continue;

    const jsonFiles = fs.readdirSync(versionDir)
      .filter((entry) => entry.endsWith(".json"))
      .sort();

    for (const jsonFile of jsonFiles) {
      const fixturePath = path.join(versionDir, jsonFile);
      try {
        fixtures.push({
          version,
          value: JSON.parse(fs.readFileSync(fixturePath, "utf8")),
        });
      } catch (error) {
        throw new Error(`could not read ${path.relative(repoRoot, fixturePath)}: ${error.message}`);
      }
    }
  }

  return fixtures;
}

function hasAll(actualValues, requiredValues) {
  const actual = new Set(actualValues || []);
  return requiredValues.every((value) => actual.has(value));
}

function matchesFilters(fixture, filters) {
  if (filters.versions.length > 0 && !filters.versions.includes(fixture.version)) {
    return false;
  }

  if (!hasAll(fixture.value.features, filters.features)) {
    return false;
  }

  if (!hasAll(fixture.value.tags, filters.tags)) {
    return false;
  }

  return true;
}

function main() {
  const filters = parseArgs(process.argv.slice(2));
  let fixtures;

  try {
    fixtures = readFixtures();
  } catch (error) {
    process.stderr.write(`error: ${error.message}\n`);
    process.exit(1);
  }

  const values = fixtures
    .filter((fixture) => matchesFilters(fixture, filters))
    .map((fixture) => fixture.value);

  process.stdout.write(JSON.stringify(values, null, filters.compact ? 0 : 2));
  process.stdout.write("\n");
}

main();
