  "tests": [
    {
      "description": "i31 integer bit operations",
      "steps": [
        {
          "description": "count set bits in an OCaml immediate integer",
          "type": "function.invoke",
          "function": "Base_int_math_int_popcount",
          "params": [
            {
              "type": "i32",
              "value": "45"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "4"
            }
          ]
        },
        {
          "description": "count leading zeroes after OCaml integer tagging",
          "type": "function.invoke",
          "function": "Base_int_math_int_clz",
          "params": [
            {
              "type": "i32",
              "value": "1"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "30"
            }
          ]
        },
        {
          "description": "count trailing zeroes in an OCaml immediate integer",
          "type": "function.invoke",
          "function": "Base_int_math_int_ctz",
          "params": [
            {
              "type": "i32",
              "value": "16"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "4"
            }
          ]
        }
      ]
    },
    {
      "description": "integer exponentiation loop paths",
      "steps": [
        {
          "description": "non-zero exponent exercises the multiply and square loop",
          "type": "function.invoke",
          "function": "Base_int_math_int_pow_stub",
          "params": [
            {
              "type": "i32",
              "value": "3"
            },
            {
              "type": "i32",
              "value": "4"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "81"
            }
          ]
        },
        {
          "description": "zero exponent exercises the loop exit path",
          "type": "function.invoke",
          "function": "Base_int_math_int_pow_stub",
          "params": [
            {
              "type": "i32",
              "value": "7"
            },
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "1"
            }
          ]
        }
      ]
    },
    {
      "description": "mutable global state exposed through an OCaml runtime helper",
      "steps": [
        {
          "type": "global.read",
          "global": "Base_am_testing_flag",
          "assert": {
            "type": "value",
            "value": {
              "type": "i32",
              "value": "0"
            }
          }
        },
        {
          "type": "global.write",
          "global": "Base_am_testing_flag",
          "value": {
            "type": "i32",
            "value": "1"
          }
        },
        {
          "type": "function.invoke",
          "function": "Base_am_testing",
          "params": [
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "1"
            }
          ]
        },
        {
          "type": "global.read",
          "global": "Base_am_testing_flag",
          "assert": {
            "type": "value",
            "value": {
              "type": "i32",
              "value": "1"
            }
          }
        }
      ]
    }
  ],
