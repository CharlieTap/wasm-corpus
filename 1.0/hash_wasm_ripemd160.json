{
  "$schema": "../schema/fixture.schema.json",
  "name": "hash_wasm_ripemd160",
  "description": "RIPEMD-160 digest kernel from the hash-wasm npm package.",
  "path": "hash_wasm_ripemd160.wasm",
  "wat": {
    "status": "present",
    "path": "hash_wasm_ripemd160.wat"
  },
  "features": [],
  "tags": [
    "crypto",
    "hash",
    "hash-wasm",
    "npm",
    "real-world",
    "ripemd160"
  ],
  "exports": [
    {
      "name": "memory",
      "kind": "memory",
      "type": "(memory 2 2)"
    },
    {
      "name": "Hash_GetBuffer",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Init",
      "kind": "function",
      "type": "(func)"
    },
    {
      "name": "ripemd160_update",
      "kind": "function",
      "type": "(func (param i32 i32))"
    },
    {
      "name": "Hash_Update",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "Hash_Final",
      "kind": "function",
      "type": "(func)"
    },
    {
      "name": "Hash_GetState",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Calculate",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "STATE_SIZE",
      "kind": "global",
      "type": "(global i32)"
    }
  ],
  "tests": [
    {
      "description": "calculate RIPEMD-160 digests for empty and short inputs",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "hash an empty message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the empty-message digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "9c1185a5c5e9fc54612808977ee8f548b2258d31"
            }
          }
        },
        {
          "type": "memory.write",
          "description": "write the short message \"abc\"",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "616263"
          }
        },
        {
          "type": "function.invoke",
          "description": "hash a short message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "3"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the abc digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "8eb208f7e05d987a9b044a8e98c6b087f15a0bfc"
            }
          }
        }
      ]
    },
    {
      "description": "stream RIPEMD-160 input in two chunks",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "initialize streaming state",
          "function": "Hash_Init",
          "params": [],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the first chunk",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "54686520717569636b2062726f776e20"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the first chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "16"
            }
          ],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the second chunk over the input buffer",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "666f78206a756d7073206f76657220746865206c617a7920646f67"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the second chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "27"
            }
          ],
          "results": []
        },
        {
          "type": "function.invoke",
          "description": "finalize the digest",
          "function": "Hash_Final",
          "params": [],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the streamed pangram digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "37f332f68db77bd9d7edd4969571ad671cf9dd3b"
            }
          }
        }
      ]
    }
  ],
  "sha256": "bc3eaee96076002181fe43ec853b8417b9f02af17cefa5281dc8e79942345aea",
  "source": {
    "contributor": "human",
    "path": "dist/index.esm.js embedded wasmJson for ripemd160",
    "url": "https://www.npmjs.com/package/hash-wasm/v/4.12.0",
    "description": "The RIPEMD-160 WebAssembly binary embedded in hash-wasm 4.12.0."
  },
  "toolchain": {
    "name": "Binaryen",
    "version": "wasm-opt version 125",
    "command": "./scripts/prepare"
  },
  "notes": "The tests cover both the one-shot Hash_Calculate path and the streaming Hash_Init/Hash_Update/Hash_Final path."
}
