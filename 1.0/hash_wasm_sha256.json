{
  "$schema": "../schema/fixture.schema.json",
  "name": "hash_wasm_sha256",
  "description": "SHA-256 digest kernel from the hash-wasm npm package.",
  "path": "hash_wasm_sha256.wasm",
  "wat": {
    "status": "present",
    "path": "hash_wasm_sha256.wat"
  },
  "features": [],
  "tags": [
    "crypto",
    "hash",
    "hash-wasm",
    "npm",
    "real-world",
    "sha256"
  ],
  "exports": [
    {
      "name": "memory",
      "kind": "memory",
      "type": "(memory 2 2)"
    },
    {
      "name": "Hash_GetBuffer",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Init",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "Hash_Update",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "Hash_Final",
      "kind": "function",
      "type": "(func)"
    },
    {
      "name": "Hash_GetState",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Calculate",
      "kind": "function",
      "type": "(func (param i32 i32))"
    },
    {
      "name": "STATE_SIZE",
      "kind": "global",
      "type": "(global i32)"
    }
  ],
  "tests": [
    {
      "description": "calculate SHA-256 digests for empty and short inputs",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "hash an empty message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "0"
            },
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the empty-message digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
            }
          }
        },
        {
          "type": "memory.write",
          "description": "write the short message \"abc\"",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "616263"
          }
        },
        {
          "type": "function.invoke",
          "description": "hash a short message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "3"
            },
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the abc digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
            }
          }
        }
      ]
    },
    {
      "description": "stream SHA-256 input in two chunks",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "initialize streaming state",
          "function": "Hash_Init",
          "params": [
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the first chunk",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "54686520717569636b2062726f776e20"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the first chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "16"
            }
          ],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the second chunk over the input buffer",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "666f78206a756d7073206f76657220746865206c617a7920646f67"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the second chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "27"
            }
          ],
          "results": []
        },
        {
          "type": "function.invoke",
          "description": "finalize the digest",
          "function": "Hash_Final",
          "params": [],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the streamed pangram digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "d7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592"
            }
          }
        }
      ]
    }
  ],
  "sha256": "aa926317d14b31d72df140096297ba571f17b2f34bf8b0783ea061cdbf53b29e",
  "source": {
    "contributor": "human",
    "path": "dist/index.esm.js embedded wasmJson for sha256",
    "url": "https://www.npmjs.com/package/hash-wasm/v/4.12.0",
    "description": "The SHA-256 WebAssembly binary embedded in hash-wasm 4.12.0."
  },
  "toolchain": {
    "name": "Binaryen",
    "version": "wasm-opt version 125",
    "command": "./scripts/prepare"
  },
  "notes": "The tests cover both the one-shot Hash_Calculate path and the streaming Hash_Init/Hash_Update/Hash_Final path."
}
