{
  "$schema": "../schema/fixture.schema.json",
  "name": "mod_inverse",
  "description": "Brute-force modular multiplicative inverse over positive i32 inputs, returning the first inverse in 1..m-1 or 0 when no inverse exists.",
  "path": "mod_inverse.wasm",
  "wat": {
    "status": "present",
    "path": "mod_inverse.wat"
  },
  "features": [],
  "tags": [
    "algorithm",
    "numeric",
    "modular-arithmetic",
    "loop",
    "branching"
  ],
  "exports": [
    {
      "name": "mod_inverse",
      "kind": "function",
      "type": "(func (param i32 i32) (result i32))"
    }
  ],
  "sha256": "8d636b77b4115ae9f1b3a687b4e19edf13132bf746d735c0a276c2dbf67eccb9",
  "source": {
    "contributor": "ai",
    "language": "wat",
    "description": "AI-authored modular inverse fixture for the corpus"
  },
  "toolchain": {
    "name": "Binaryen",
    "version": "wasm-opt version 125",
    "command": "./scripts/prepare"
  },
  "notes": "This fixture intentionally uses a simple bounded search instead of the extended Euclidean algorithm so the WAT stays small while still exercising loops, modulo arithmetic, early returns, and an exhausted-search fallback.",
  "tests": [
    {
      "description": "small-prime-modulus",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "3"
            },
            {
              "type": "i32",
              "value": "11"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "4"
            }
          ]
        }
      ]
    },
    {
      "description": "later-match",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "10"
            },
            {
              "type": "i32",
              "value": "17"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "12"
            }
          ]
        }
      ]
    },
    {
      "description": "not-coprime",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "6"
            },
            {
              "type": "i32",
              "value": "9"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "0"
            }
          ]
        }
      ]
    },
    {
      "description": "invalid-modulus",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "5"
            },
            {
              "type": "i32",
              "value": "1"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "0"
            }
          ]
        }
      ]
    },
    {
      "description": "identity",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "1"
            },
            {
              "type": "i32",
              "value": "19"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "1"
            }
          ]
        }
      ]
    },
    {
      "description": "large-input-no-wraparound",
      "steps": [
        {
          "type": "function.invoke",
          "function": "mod_inverse",
          "params": [
            {
              "type": "i32",
              "value": "1837719394"
            },
            {
              "type": "i32",
              "value": "5"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "4"
