{
  "$schema": "../schema/fixture.schema.json",
  "name": "hash_wasm_md5",
  "description": "MD5 digest kernel from the hash-wasm npm package.",
  "path": "hash_wasm_md5.wasm",
  "wat": {
    "status": "present",
    "path": "hash_wasm_md5.wat"
  },
  "features": [],
  "tags": [
    "crypto",
    "hash",
    "hash-wasm",
    "md5",
    "npm",
    "real-world"
  ],
  "exports": [
    {
      "name": "memory",
      "kind": "memory",
      "type": "(memory 2 2)"
    },
    {
      "name": "Hash_GetBuffer",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Init",
      "kind": "function",
      "type": "(func)"
    },
    {
      "name": "Hash_Update",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "Hash_Final",
      "kind": "function",
      "type": "(func)"
    },
    {
      "name": "Hash_GetState",
      "kind": "function",
      "type": "(func (result i32))"
    },
    {
      "name": "Hash_Calculate",
      "kind": "function",
      "type": "(func (param i32))"
    },
    {
      "name": "STATE_SIZE",
      "kind": "global",
      "type": "(global i32)"
    }
  ],
  "tests": [
    {
      "description": "calculate MD5 digests for empty and short inputs",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "hash an empty message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "0"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the empty-message digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "d41d8cd98f00b204e9800998ecf8427e"
            }
          }
        },
        {
          "type": "memory.write",
          "description": "write the short message \"abc\"",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "616263"
          }
        },
        {
          "type": "function.invoke",
          "description": "hash a short message in one call",
          "function": "Hash_Calculate",
          "params": [
            {
              "type": "i32",
              "value": "3"
            }
          ],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the abc digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "900150983cd24fb0d6963f7d28e17f72"
            }
          }
        }
      ]
    },
    {
      "description": "stream MD5 input in two chunks",
      "steps": [
        {
          "type": "function.invoke",
          "function": "Hash_GetBuffer",
          "params": [],
          "results": [
            {
              "type": "i32",
              "capture": "buffer_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "initialize streaming state",
          "function": "Hash_Init",
          "params": [],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the first chunk",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "54686520717569636b2062726f776e20"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the first chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "16"
            }
          ],
          "results": []
        },
        {
          "type": "memory.write",
          "description": "write the second chunk over the input buffer",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "bytes": {
            "encoding": "hex",
            "value": "666f78206a756d7073206f76657220746865206c617a7920646f67"
          }
        },
        {
          "type": "function.invoke",
          "description": "absorb the second chunk",
          "function": "Hash_Update",
          "params": [
            {
              "type": "i32",
              "value": "27"
            }
          ],
          "results": []
        },
        {
          "type": "function.invoke",
          "description": "finalize the digest",
          "function": "Hash_Final",
          "params": [],
          "results": []
        },
        {
          "type": "memory.read",
          "description": "assert the streamed pangram digest",
          "memory": "memory",
          "offset": {
            "var": "buffer_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "hex",
              "value": "9e107d9d372bb6826bd81d3542a419d6"
            }
          }
        }
      ]
    }
  ],
  "sha256": "d036688d00424123c9b1ab61fcdb18c031bbb8796be0829281a1e77bcced2e6a",
  "source": {
    "contributor": "human",
    "path": "dist/index.esm.js embedded wasmJson for md5",
    "url": "https://www.npmjs.com/package/hash-wasm/v/4.12.0",
    "description": "The MD5 WebAssembly binary embedded in hash-wasm 4.12.0."
  },
  "toolchain": {
    "name": "Binaryen",
    "version": "wasm-opt version 125",
    "command": "./scripts/prepare"
  },
  "notes": "The tests cover both the one-shot Hash_Calculate path and the streaming Hash_Init/Hash_Update/Hash_Final path."
}
