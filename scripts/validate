#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ./scripts/validate <path/to/module.wasm> [path/to/another.wasm ...]

Validates corpus manifests against the JSON Schema, runs Binaryen over each wasm
file and its sibling wat file, then checks that the binary does not shrink
suspiciously after optimization.
EOF
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

binaryen_version() {
  wasm-opt --version | sed -E 's/.*version ([0-9]+).*/\1/'
}

file_size() {
  if stat -f%z "$1" >/dev/null 2>&1; then
    stat -f%z "$1"
  else
    stat -c%s "$1"
  fi
}

percent_reduction() {
  local original=$1
  local optimized=$2

  if (( original == 0 || optimized >= original )); then
    printf '0'
  else
    printf '%d' $(( (original - optimized) * 100 / original ))
  fi
}

validate_manifests() {
  local manifests=("$@")
  local ajv_args=()
  local manifest

  if (( ${#manifests[@]} == 0 )); then
    return 0
  fi

  if ! command -v npx >/dev/null 2>&1; then
    fail "npx is required to validate manifests against schema/manifest.schema.json"
  fi

  for manifest in "${manifests[@]}"; do
    ajv_args+=("-d" "$manifest")
  done

  npx --yes ajv-cli@5 validate \
    --spec=draft2020 \
    -s schema/manifest.schema.json \
    "${ajv_args[@]}"
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

missing=()
for cmd in wasm-opt wasm-dis wasm-as; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    missing+=("$cmd")
  fi
done

if (( ${#missing[@]} > 0 )); then
  warn "Binaryen is required to validate corpus binaries."
  warn "Missing command(s): ${missing[*]}"
  warn "Install Binaryen, then rerun this script. On macOS: brew install binaryen"
  exit 1
fi

binaryen=$(binaryen_version)
tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/wasm-corpus-validate.XXXXXX")
trap 'rm -rf "$tmpdir"' EXIT

min_size_check_bytes=${WASM_CORPUS_VALIDATE_MIN_SIZE:-1024}
max_reduction_percent=${WASM_CORPUS_VALIDATE_MAX_REDUCTION_PERCENT:-20}
max_reduction_bytes=${WASM_CORPUS_VALIDATE_MAX_REDUCTION_BYTES:-512}

manifest_list=$tmpdir/manifests.txt
find . -mindepth 2 -maxdepth 2 -name manifest.json | sort > "$manifest_list"

manifests=()
while IFS= read -r manifest; do
  manifests+=("$manifest")
done < "$manifest_list"

validate_manifests "${manifests[@]}"

status=0
index=0

for wasm in "$@"; do
  index=$((index + 1))
  if [[ $wasm != *.wasm ]]; then
    printf 'error: expected a .wasm file, got: %s\n' "$wasm" >&2
    status=1
    continue
  fi

  if [[ ! -f $wasm ]]; then
    printf 'error: file does not exist: %s\n' "$wasm" >&2
    status=1
    continue
  fi

  wat=${wasm%.wasm}.wat
  if [[ ! -f $wat ]]; then
    printf 'error: missing matching wat file: %s\n' "$wat" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    printf '       run ./scripts/prepare %s to generate it\n' "$wasm" >&2
    status=1
    continue
  fi

  work=$tmpdir/$index
  mkdir -p "$work"
  optimized=$work/optimized.wasm
  disassembled=$work/module.wat
  wat_wasm=$work/wat.wasm
  wat_optimized=$work/wat-optimized.wasm

  if ! wasm-opt "$wasm" -O1 -o "$optimized"; then
    printf 'error: Binaryen could not optimize %s\n' "$wasm" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    status=1
    continue
  fi

  if ! wasm-dis "$optimized" -o "$disassembled"; then
    printf 'error: Binaryen could not disassemble optimized output for %s\n' "$wasm" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    status=1
    continue
  fi

  if ! wasm-as "$wat" -o "$wat_wasm"; then
    printf 'error: Binaryen could not assemble sibling wat file %s\n' "$wat" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    status=1
    continue
  fi

  if ! wasm-opt "$wat_wasm" -O1 -o "$wat_optimized"; then
    printf 'error: Binaryen could not optimize sibling wat file %s\n' "$wat" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    status=1
    continue
  fi

  if ! cmp -s "$optimized" "$wat_optimized"; then
    printf 'error: %s does not roundtrip to the same optimized module as %s\n' "$wat" "$wasm" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    printf '       run ./scripts/prepare %s to refresh both files\n' "$wasm" >&2
    status=1
    continue
  fi

  original_size=$(file_size "$wasm")
  optimized_size=$(file_size "$optimized")
  reduction_bytes=0
  if (( optimized_size < original_size )); then
    reduction_bytes=$(( original_size - optimized_size ))
  fi
  reduction_percent=$(percent_reduction "$original_size" "$optimized_size")

  if (( original_size >= min_size_check_bytes && reduction_bytes >= max_reduction_bytes && reduction_percent > max_reduction_percent )); then
    printf 'error: %s shrank substantially when Binaryen was applied\n' "$wasm" >&2
    printf '       Binaryen version used: %s\n' "$binaryen" >&2
    printf '       original size:  %s bytes\n' "$original_size" >&2
    printf '       optimized size: %s bytes\n' "$optimized_size" >&2
    printf '       reduction:      %s bytes (%s%%)\n' "$reduction_bytes" "$reduction_percent" >&2
    printf '       this usually means Binaryen has not been applied yet; run ./scripts/prepare %s\n' "$wasm" >&2
    status=1
    continue
  fi

  printf 'Validated %s with Binaryen %s (optimized size %s bytes, reduction %s bytes / %s%%)\n' \
    "$wasm" "$binaryen" "$optimized_size" "$reduction_bytes" "$reduction_percent"
done

exit "$status"
