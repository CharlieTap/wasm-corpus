#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ./scripts/validate <path/to/module.wasm> [path/to/another.wasm ...]

Regenerates the prepared wasm and sibling wat files in a temporary directory
using the same Binaryen steps as ./scripts/prepare, then checks that the checked-in
files match.
EOF
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

binaryen_version() {
  "$1" --version | awk '{print $NF}'
}

sha256() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    fail "sha256sum or shasum is required"
  fi
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

required_binaryen_version=${WASM_CORPUS_BINARYEN_VERSION:-125}

missing=()
for cmd in wasm-opt wasm-dis wasm-as; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    missing+=("$cmd")
  fi
done

if (( ${#missing[@]} > 0 )); then
  warn "Binaryen is required to validate corpus binaries."
  warn "Missing command(s): ${missing[*]}"
  warn "Install Binaryen $required_binaryen_version, then rerun this script."
  exit 1
fi

for cmd in wasm-opt wasm-dis wasm-as; do
  version=$(binaryen_version "$cmd")
  if [[ $version != "$required_binaryen_version" ]]; then
    fail "$cmd version $required_binaryen_version is required, found $version. Set WASM_CORPUS_BINARYEN_VERSION to override."
  fi
done

tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/wasm-corpus-validate.XXXXXX")
trap 'rm -rf "$tmpdir"' EXIT

prepare_binary() {
  local input=$1
  local output=$2
  local output_wat=$3
  local work=$4
  local current=$input

  for pass in 1 2 3 4 5; do
    local candidate=$work/candidate-$pass.wasm
    local candidate_wat=$work/candidate-$pass.wat
    local roundtrip=$work/roundtrip-$pass.wasm
    local checked=$work/checked-$pass.wasm

    wasm-opt "$current" -O1 -o "$candidate"
    wasm-dis "$candidate" -o "$candidate_wat"
    wasm-as "$candidate_wat" -o "$roundtrip"
    wasm-opt "$roundtrip" -O1 -o "$checked"

    if cmp -s "$candidate" "$checked"; then
      cp "$candidate" "$output"
      cp "$candidate_wat" "$output_wat"
      return 0
    fi

    current=$checked
  done

  printf 'error: Binaryen output did not stabilize after 5 passes for %s\n' "$input" >&2
  return 1
}

status=0
index=0

for wasm in "$@"; do
  index=$((index + 1))
  if [[ $wasm != *.wasm ]]; then
    printf 'error: expected a .wasm file, got: %s\n' "$wasm" >&2
    status=1
    continue
  fi

  if [[ ! -f $wasm ]]; then
    printf 'error: file does not exist: %s\n' "$wasm" >&2
    status=1
    continue
  fi

  wat=${wasm%.wasm}.wat
  if [[ ! -f $wat ]]; then
    printf 'error: missing matching wat file: %s\n' "$wat" >&2
    printf '       run ./scripts/prepare %s\n' "$wasm" >&2
    status=1
    continue
  fi

  work=$tmpdir/$index
  mkdir -p "$work"
  prepared=$work/prepared.wasm
  wat_tmp=$work/module.wat

  if ! prepare_binary "$wasm" "$prepared" "$wat_tmp" "$work"; then
    status=1
    continue
  fi

  file_status=0

  if ! cmp -s "$prepared" "$wasm"; then
    printf 'error: %s is not prepared\n' "$wasm" >&2
    printf '       expected sha256: %s\n' "$(sha256 "$prepared")" >&2
    printf '       actual sha256:   %s\n' "$(sha256 "$wasm")" >&2
    printf '       run ./scripts/prepare %s\n' "$wasm" >&2
    file_status=1
  fi

  if ! cmp -s "$wat_tmp" "$wat"; then
    printf 'error: %s is out of date\n' "$wat" >&2
    printf '       expected sha256: %s\n' "$(sha256 "$wat_tmp")" >&2
    printf '       actual sha256:   %s\n' "$(sha256 "$wat")" >&2
    printf '       run ./scripts/prepare %s\n' "$wasm" >&2
    file_status=1
  fi

  if (( file_status == 0 )); then
    printf 'Validated %s\n' "$wasm"
  else
    status=1
  fi
done

exit "$status"
