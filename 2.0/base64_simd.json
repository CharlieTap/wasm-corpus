{
  "$schema": "../schema/fixture.schema.json",
  "name": "base64_simd",
  "description": "SIMD-accelerated Base64 encoder/decoder module from @addmaple/base64, using bulk memory and v128 instructions in its real package build.",
  "path": "base64_simd.wasm",
  "wat": {
    "status": "present",
    "path": "base64_simd.wat"
  },
  "features": [
    "bulk-memory",
    "mutable-globals",
    "reference-types",
    "simd"
  ],
  "exports": [
    {
      "name": "memory",
      "kind": "memory",
      "type": "(memory 17)"
    },
    {
      "name": "alloc_bytes",
      "kind": "function",
      "type": "(func (param i32) (result i32))"
    },
    {
      "name": "free_bytes",
      "kind": "function",
      "type": "(func (param i32 i32))"
    },
    {
      "name": "encode_std",
      "kind": "function",
      "type": "(func (param i32 i32 i32 i32) (result i32))"
    },
    {
      "name": "encode_url",
      "kind": "function",
      "type": "(func (param i32 i32 i32 i32) (result i32))"
    },
    {
      "name": "decode_std",
      "kind": "function",
      "type": "(func (param i32 i32 i32 i32) (result i32))"
    },
    {
      "name": "decode_url",
      "kind": "function",
      "type": "(func (param i32 i32 i32 i32) (result i32))"
    },
    {
      "name": "__data_end",
      "kind": "global",
      "type": "(global i32)"
    },
    {
      "name": "__heap_base",
      "kind": "global",
      "type": "(global i32)"
    }
  ],
  "tags": [
    "base64",
    "encoding",
    "simd",
    "bulk-memory",
    "real-world",
    "npm"
