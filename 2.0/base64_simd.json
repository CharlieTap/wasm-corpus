    "contributor": "human",
    "url": "https://www.npmjs.com/package/@addmaple/base64/v/0.3.2",
    "path": "dist/wasm/base64_simd.simd.wasm",
    "language": "rust",
    "description": "MIT-licensed @addmaple/base64 0.3.2 SIMD WebAssembly build from npm, repository git+https://github.com/addmaple/base64-simd.git"
  },
  "toolchain": {
    "name": "Binaryen",
    "version": "wasm-opt version 125",
    "command": "./scripts/prepare"
  },
  "notes": "The tests allocate input/output buffers through exported allocator functions, write input bytes into exported linear memory, call encode/decode exports, assert output bytes, and free the buffers. The longer cases cross multiple SIMD-sized chunks.",
  "tests": [
    {
      "description": "encode-std-hello-question",
      "steps": [
        {
          "type": "function.invoke",
          "description": "alloc input",
          "function": "alloc_bytes",
          "params": [
            {
              "type": "i32",
              "value": "6"
            }
          ],
          "results": [
            {
              "type": "i32",
              "capture": "input_ptr"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "alloc output",
          "function": "alloc_bytes",
          "params": [
            {
              "type": "i32",
              "value": "8"
            }
          ],
          "results": [
            {
              "type": "i32",
              "capture": "output_ptr"
            }
          ]
        },
        {
          "type": "memory.write",
          "description": "write input",
          "memory": "memory",
          "offset": {
            "var": "input_ptr"
          },
          "bytes": {
            "encoding": "utf8",
            "value": "Hello?"
          }
        },
        {
          "type": "function.invoke",
          "description": "encode",
          "function": "encode_std",
          "params": [
            {
              "type": "i32",
              "var": "input_ptr"
            },
            {
              "type": "i32",
              "value": "6"
            },
            {
              "type": "i32",
              "var": "output_ptr"
            },
            {
              "type": "i32",
              "value": "8"
            }
          ],
          "results": [
            {
              "type": "i32",
              "value": "8"
            }
          ]
        },
        {
          "type": "memory.read",
          "description": "read encoded output",
          "memory": "memory",
          "offset": {
            "var": "output_ptr"
          },
          "assert": {
            "type": "bytes",
            "bytes": {
              "encoding": "utf8",
              "value": "SGVsbG8/"
            }
          }
        },
        {
          "type": "function.invoke",
          "description": "free input",
          "function": "free_bytes",
          "params": [
            {
              "type": "i32",
              "var": "input_ptr"
            },
            {
              "type": "i32",
              "value": "6"
            }
          ],
          "results": []
        },
        {
          "type": "function.invoke",
          "description": "free output",
          "function": "free_bytes",
          "params": [
            {
              "type": "i32",
              "var": "output_ptr"
            },
            {
              "type": "i32",
              "value": "8"
            }
          ],
          "results": []
        }
      ]
    },
