  "tests": [
    {
      "description": "compress and decompress a repeated payload",
      "notes": "Uses the raw minified exports from the package's Emscripten glue: `g` is constructors, `i` is `ZSTD_compressBound`, `m` is `ZSTD_compress`, `p` is `ZSTD_getFrameContentSize`, `r` is `ZSTD_decompress`, `s` is `malloc`, and `h` is `ZSTD_isError`.",
      "steps": [
        {
          "type": "function.invoke",
          "description": "run static constructors",
          "function": "g",
          "params": [],
          "results": []
        },
        {
          "type": "function.invoke",
          "description": "allocate input payload",
          "function": "s",
          "params": [
            {
              "type": "i32",
              "value": "95"
            }
          ],
          "results": [
            {
              "type": "i32",
              "capture": "input"
            }
          ]
        },
        {
          "type": "memory.write",
          "memory": "f",
          "offset": {
            "var": "input"
          },
          "bytes": {
            "encoding": "utf8",
            "value": "Zstandard wasm fixture: repeated repeated repeated text with enough words to compress usefully."
          }
        },
        {
          "type": "function.invoke",
          "description": "calculate compression bound",
          "function": "i",
          "params": [
            {
              "type": "i32",
              "value": "95"
            }
          ],
          "results": [
            {
              "type": "i32",
              "capture": "bound"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "allocate compression output",
          "function": "s",
          "params": [
            {
              "type": "i32",
              "var": "bound"
            }
          ],
          "results": [
            {
              "type": "i32",
              "capture": "compressed"
            }
          ]
        },
        {
          "type": "function.invoke",
          "description": "compress at level 3",
          "function": "m",
          "params": [
            {
              "type": "i32",
              "var": "compressed"
            },
            {
              "type": "i32",
              "var": "bound"
            },
            {
              "type": "i32",
              "var": "input"
            },
            {
              "type": "i32",
              "value": "95"
            },
            {
